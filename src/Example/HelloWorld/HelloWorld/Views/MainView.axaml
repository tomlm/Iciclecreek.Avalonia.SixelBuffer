<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HelloWorld.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="HelloWorld.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>

    <!--
      14-second looping timeline
        0.00s  -  1.50s  (  0.00% - 10.71%)  slide in from left, no rotation
        1.50s  -  5.50s  ( 10.71% - 39.29%)  hold centre
        5.50s  -  8.50s  ( 39.29% - 60.71%)  spin 360 degrees
        8.50s  - 10.50s  ( 60.71% - 75.00%)  grow font 50%
       10.50s  - 12.50s  ( 75.00% - 89.29%)  shrink font back
       12.50s  - 14.00s  ( 89.29% - 100.00%) slide out to right, no rotation
    -->

    <!-- Outer panel: horizontal translation only -->
    <Style Selector="Panel.fly">
      <Style.Animations>
        <Animation Duration="0:0:14" IterationCount="INFINITE" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="-700"/>
          </KeyFrame>
          <KeyFrame Cue="10.71%">
            <Setter Property="TranslateTransform.X" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="89.29%">
            <Setter Property="TranslateTransform.X" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="700"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Inner panel: spin 360 only during the spin phase, stationary otherwise -->
    <Style Selector="Panel.spin">
      <Style.Animations>
        <Animation Duration="0:0:14" IterationCount="INFINITE">
          <KeyFrame Cue="0%">
            <Setter Property="RotateTransform.Angle" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="39.29%">
            <Setter Property="RotateTransform.Angle" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="60.71%">
            <Setter Property="RotateTransform.Angle" Value="360"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="RotateTransform.Angle" Value="360"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

  </UserControl.Styles>

  <Grid RowDefinitions="*, Auto">

    <!-- Outer panel drives horizontal slide -->
    <Panel Grid.Row="0"
           Classes="fly"
           HorizontalAlignment="Center"
           VerticalAlignment="Center">
      <Panel.RenderTransform>
        <TranslateTransform X="-700"/>
      </Panel.RenderTransform>

      <!-- Inner panel drives the 360 spin -->
      <Panel Classes="spin">
        <Panel.RenderTransform>
          <RotateTransform Angle="0"/>
        </Panel.RenderTransform>

        <!-- TextBlock: fade in/out + steady neon glow while visible -->
        <TextBlock Text="Welcome to Avalonia!"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="DeepSkyBlue"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="1">

          <TextBlock.Effect>
            <DropShadowEffect BlurRadius="0" Color="DeepSkyBlue" OffsetX="0" OffsetY="0"/>
          </TextBlock.Effect>

          <TextBlock.Styles>
            <Style Selector="TextBlock">
              <Style.Animations>

                <!-- Neon glow: ramps up on arrival, holds, ramps down on departure -->
                <Animation Duration="0:0:14" IterationCount="INFINITE">
                  <KeyFrame Cue="0%">
                    <Setter Property="TextBlock.Effect">
                      <Setter.Value>
                        <DropShadowEffect BlurRadius="0" Color="DeepSkyBlue" OffsetX="0" OffsetY="0"/>
                      </Setter.Value>
                    </Setter>
                  </KeyFrame>
                  <KeyFrame Cue="10.71%">
                    <Setter Property="TextBlock.Effect">
                      <Setter.Value>
                        <DropShadowEffect BlurRadius="18" Color="DeepSkyBlue" OffsetX="0" OffsetY="0"/>
                      </Setter.Value>
                    </Setter>
                  </KeyFrame>
                  <KeyFrame Cue="89.29%">
                    <Setter Property="TextBlock.Effect">
                      <Setter.Value>
                        <DropShadowEffect BlurRadius="18" Color="DeepSkyBlue" OffsetX="0" OffsetY="0"/>
                      </Setter.Value>
                    </Setter>
                  </KeyFrame>
                  <KeyFrame Cue="100%">
                    <Setter Property="TextBlock.Effect">
                      <Setter.Value>
                        <DropShadowEffect BlurRadius="0" Color="DeepSkyBlue" OffsetX="0" OffsetY="0"/>
                      </Setter.Value>
                    </Setter>
                  </KeyFrame>
                </Animation>

                <!-- Font size: grow 50% after spin, shrink back before slide-out -->
                <Animation Duration="0:0:14" IterationCount="INFINITE" Easing="SineEaseInOut">
                  <KeyFrame Cue="0%">
                    <Setter Property="FontSize" Value="32"/>
                  </KeyFrame>
                  <KeyFrame Cue="60.71%">
                    <Setter Property="FontSize" Value="32"/>
                  </KeyFrame>
                  <KeyFrame Cue="75%">
                    <Setter Property="FontSize" Value="48"/>
                  </KeyFrame>
                  <KeyFrame Cue="89.29%">
                    <Setter Property="FontSize" Value="32"/>
                  </KeyFrame>
                  <KeyFrame Cue="100%">
                    <Setter Property="FontSize" Value="32"/>
                  </KeyFrame>
                </Animation>

              </Style.Animations>
            </Style>
          </TextBlock.Styles>

        </TextBlock>
      </Panel>
    </Panel>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="12"
                Margin="0,0,0,20">
      <Button Content="Open File"
              Padding="20,8"
              FontSize="16"
              Click="OnOpenFileClick"/>
      <Button Content="Exit"
              Padding="20,8"
              FontSize="16"
              Click="OnExitClick"/>
    </StackPanel>
  </Grid>
</UserControl>
